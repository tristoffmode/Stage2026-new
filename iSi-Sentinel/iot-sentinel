server {
    listen 8050 ssl;
    server_name iot.is-informatiques.fr;

    # Vos certificats SSL existants
    ssl_certificate /etc/letsencrypt/live/iot.is-informatiques.fr/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/iot.is-informatiques.fr/privkey.pem;

    # Paramètres SSL améliorés
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256;
    
    # Dossier où vous avez copié les fichiers de build
    root /var/www/iot-sentinel/;
    index login.html;
    
    # Définir les headers de sécurité
    add_header X-Content-Type-Options nosniff;
    add_header X-Frame-Options SAMEORIGIN;

    # Mise en cache des assets statiques
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
    }

    # Configuration pour Expo Router (SPA)
    location / {
        try_files $uri $uri/ /login.html;
    }

    # Pour rediriger les requêtes API vers votre backend Python
    location /api/ {
        proxy_pass https://127.0.0.1:5001;  # Notez le HTTPS ici
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Si votre API utilise des WebSockets (augmente la compatibilité)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Gestion des erreurs
    error_page 404 /index.html;
    error_log /var/log/nginx/iot-sentinel-error.log;
    access_log /var/log/nginx/iot-sentinel-access.log;
}